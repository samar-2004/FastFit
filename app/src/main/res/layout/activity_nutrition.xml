<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".NutritionActivity">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="70dp"
        android:background="@color/red"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="32dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nutrition"
            android:textColor="#FFFFFF"
            android:textSize="25sp"
            android:textStyle="bold" />

    </LinearLayout>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_color"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- ====== PROTEIN SHAKE ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:background="@drawable/workout_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:src="@drawable/protein_shake"
                    android:contentDescription="Protein Shake"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeOverlay.LeftRounded" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protein Shake"
                        android:textColor="@color/black"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$8.99"
                        android:textColor="#FFdc000a"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp" />
                    <!-- Qty Controls -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/btnDecProtein"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="−"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/qty_btn_bg"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/tvQtyProtein"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/btnIncProtein"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="+"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/logo_circle_bg"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                </LinearLayout>


            </LinearLayout>

            <!-- ====== ENERGY BAR ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:background="@drawable/workout_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:src="@drawable/energy_bar"
                    android:contentDescription="Energy Bar"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeOverlay.LeftRounded" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Energy Bar"
                        android:textColor="@color/black"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$3.49"
                        android:textColor="#FFdc000a"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp" />

                    <!-- Qty Controls -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/btnDecEnergy"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="−"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/qty_btn_bg"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/tvQtyEnergy"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/btnIncEnergy"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="+"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/logo_circle_bg"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>


            <!-- ====== SALAD ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:background="@drawable/workout_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:src="@drawable/salad"
                    android:contentDescription="Salad"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeOverlay.LeftRounded" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Salad"
                        android:textColor="@color/black"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$6.99"
                        android:textColor="#FFdc000a"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp" />

                    <!-- Qty Controls -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/btnDecSalad"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="−"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/qty_btn_bg"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/tvQtySalad"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/btnIncSalad"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="+"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/logo_circle_bg"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>


            <!-- ====== JUICE ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:background="@drawable/workout_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:src="@drawable/juice"
                    android:contentDescription="Juice"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeOverlay.LeftRounded" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Juice"
                        android:textColor="@color/black"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$4.99"
                        android:textColor="#FFdc000a"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp" />

                    <!-- Qty Controls -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/btnDecJuice"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="−"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/qty_btn_bg"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/tvQtyJuice"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/btnIncJuice"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="+"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/logo_circle_bg"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>


            <!-- Total Row -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/workout_card_bg"
            android:orientation="vertical"
            android:paddingHorizontal="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/workout_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total: "
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="#FFdc000a"
                    android:textSize="22sp" />

            </LinearLayout>

            <!-- Confirm Button -->
            <Button
                android:id="@+id/btnConfirmNutrition"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="CONFIRM"
                android:textColor="#FFFFFF"
                app:backgroundTint="@color/red"
                app:cornerRadius="15dp"
                android:textSize="16sp"
                android:layout_marginBottom="24dp" />
        </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>

