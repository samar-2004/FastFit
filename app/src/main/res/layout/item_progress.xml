<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_white"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <View
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_circle_red_soft" />

    <ImageView
        android:id="@+id/imgProgressIcon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="-33dp"
        android:layout_marginEnd="22dp"
        android:src="@drawable/ic_fire"
        app:tint="@color/red"
        android:contentDescription="@string/nav_progress" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leg Press"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProgressDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Jun 14, 2026"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvProgressValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="45 min"
        android:textColor="@color/red"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
