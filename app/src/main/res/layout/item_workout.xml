<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/workout_card_bg"
    android:clipToOutline="true"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp">

        <ImageView
            android:id="@+id/imgWorkout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/light_grey"
            android:scaleType="centerCrop"
            android:contentDescription="@string/nav_workouts" />

        <TextView
            android:id="@+id/chipMuscle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="@drawable/bg_pill_red"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="Legs"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_circle_red"
            android:padding="10dp"
            android:src="@drawable/ic_play_circle"
            app:tint="@color/white"
            android:contentDescription="@string/watch_tutorial" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvWorkoutName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leg Press"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWorkoutInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="4 Sets × 12 Reps | 45 min"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="12dp">

            <Button
                android:id="@+id/btnBook"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/book_slot"
                android:textColor="@color/white"
                android:textSize="15sp"
                app:backgroundTint="@color/red"
                app:cornerRadius="14dp" />

            <Button
                android:id="@+id/btnTutorial"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="@string/watch_tutorial"
                android:textColor="@color/black"
                android:textSize="13sp"
                app:backgroundTint="@color/light_grey"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
