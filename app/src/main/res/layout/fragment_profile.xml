<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header_rounded"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imgAvatar"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:src="@drawable/ic_person"
                app:civ_border_color="#66FFFFFF"
                app:civ_border_width="2dp"
                android:background="@drawable/bg_avatar_ring"
                android:padding="2dp"
                android:contentDescription="@string/nav_profile" />

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Athlete"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="you@email.com"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_circle_white"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="🎯 Stay Fit"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical">

            <LinearLayout android:id="@+id/rowEditProfile" style="@style/ProfileRow">
                <ImageView style="@style/ProfileRowIcon" android:src="@drawable/ic_edit" />
                <TextView style="@style/ProfileRowText" android:text="@string/edit_profile" />
                <ImageView style="@style/ProfileRowChevron" android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View style="@style/ProfileDivider" />

            <LinearLayout android:id="@+id/rowBookings" style="@style/ProfileRow">
                <ImageView style="@style/ProfileRowIcon" android:src="@drawable/ic_history" />
                <TextView style="@style/ProfileRowText" android:text="@string/my_bookings" />
                <ImageView style="@style/ProfileRowChevron" android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View style="@style/ProfileDivider" />

            <LinearLayout android:id="@+id/rowSettings" style="@style/ProfileRow">
                <ImageView style="@style/ProfileRowIcon" android:src="@drawable/ic_settings" />
                <TextView style="@style/ProfileRowText" android:text="@string/settings" />
                <ImageView style="@style/ProfileRowChevron" android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <View style="@style/ProfileDivider" />

            <LinearLayout android:id="@+id/rowAbout" style="@style/ProfileRow">
                <ImageView style="@style/ProfileRowIcon" android:src="@drawable/ic_info" />
                <TextView style="@style/ProfileRowText" android:text="@string/about" />
                <ImageView style="@style/ProfileRowChevron" android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:text="@string/log_out"
            android:textColor="@color/red"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/surface"
            app:cornerRadius="15dp"
            app:icon="@drawable/ic_logout"
            app:iconGravity="textStart"
            app:iconTint="@color/red"
            app:strokeColor="@color/red"
            app:strokeWidth="1dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="FASTFit v1.0"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
