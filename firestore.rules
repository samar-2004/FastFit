rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Workout catalog: anyone signed in can read; writes are app-seeded.
    // Lock writes down to the console/admin in production by removing `allow write`.
    match /workouts/{workoutId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Per-user data: a user may only read/write their own document tree.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /bookings/{bookingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /progress/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
